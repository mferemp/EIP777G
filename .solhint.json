{
  "plugins": ["solidity"],
  "rules": {
    "compiler-version": ["error", "^0.8.24"],
    "func-visibility": ["error", { "ignoreConstructors": true }],
    "func-order": ["error", { "order": ["constructor", "receive", "fallback", "external", "public", "internal", "private"] }],
    "no-unused-vars": "error",
    "reason-string": ["error", { "maxLength": 64 }],
    "custom-errors": "error",
    "no-empty-blocks": "error",
    "no-inline-assembly": "warn",
    "no-console": "error",
    "avoid-low-level-calls": "warn",
    "use-require-messages": "off",
    "private-vars-leading-underscore": "off",
    "const-name-snakecase": "error",
    "event-name-camelcase": "error",
    "function-name-mixedcase": "error",
    "parameter-name-mixedcase": "error",
    "variable-name-mixedcase": "error",
    "no-global-import": "error",
    "imports-on-top": "error",
    "ordering": "error",
    "quotes": ["error", "double"],
    "indentation": ["error", 2],
    "bracket-spacing": "error",
    "operator-whitespace": "error",
    "max-line-length": ["error", 120],
    "max-states-count": ["warn", 25],
    "max-locals-count": ["warn", 20]
  }
}