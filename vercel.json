{
  "version": 2,
  "outputDirectory": "live",
  "functions": {
    "api/relay.js": {
      "maxDuration": 30
    },
    "api/bypass-verify.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/vendor/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, stale-while-revalidate=600"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://rpc.hyperliquid.xyz wss://rpc.hyperliquid.xyz https://*.infura.io https://*.alchemy.com https://*.quiknode.pro https://eth.llamarpc.com https://base.llamarpc.com https://arb1.arbitrum.io https://mainnet.optimism.io https://polygon-rpc.com https://bsc-dataseed.binance.org https://api.avax.network https://mainnet.base.org; img-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; upgrade-insecure-requests"
        }
      ]
    }
  ],
  "routes": [
    { "src": "^/js/genesis-verification\\.js$",  "status": 404 },
    { "src": "^/artifacts(/.*)?$",               "status": 404 },
    { "src": "^/contracts(/.*)?$",               "status": 404 },
    { "src": "^/private-artifacts(/.*)?$",       "status": 404 },
    { "src": "^/EIP777G\\.json$",                "status": 404 },
    { "src": "^/abi\\.json$",                    "status": 404 },
    { "src": "^/bytecode\\.txt$",                "status": 404 },
    { "src": "^/api/(.*)",   "dest": "/api/$1"  },
    { "src": "^/vendor/(.*)", "dest": "/vendor/$1" },
    { "src": "^/js/(.*)",    "dest": "/js/$1"   },
    { "src": "^/css/(.*)",   "dest": "/css/$1"  },
    { "handle": "filesystem" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
