# EIP777G — Environment Variables (names only, no values)
# Copy to .env.local and fill in actual values
# NEVER commit actual values — .env.local is in .gitignore

# ─────────────────────────────────────────────────────────────────
# OPERATIONAL KEYS
# ─────────────────────────────────────────────────────────────────

# Deployer burner wallet — minimally funded, signs deploy + relay txs only
# K2 never touches this machine. K3 key never stored here.
DEPLOYER_PRIVATE_KEY=

# K1 — the COMPROMISED wallet being recovered from.
# Acceptable on this machine because the contract nullifies its autonomous authority.
# K1 can only call queue() — no value movement possible without K2 authorization.
K1_PRIVATE_KEY=
K1_ADDRESS=

# K2 — off-chain EIP-712 signer. PUBLIC address only — NEVER store K2 private key here.
# K2 signs authorize() offline (Ledger / air-gapped machine / cast wallet sign-tx).
# Paste signed hex into dashboard. K2 key never touches this machine.
K2_ADDRESS=

# K3 — clean destination wallet (passive sink). PUBLIC address only.
# All swept assets forward here. Key never stored on this machine.
K3_ADDRESS=
CLEAN_WALLET=

# Fee escalation override (default: 15, escalate to 25 then 30 if not landing)
PRIORITY_GWEI=15

# Ethereum Mainnet
RPC_ETHEREUM=

# Optimism Mainnet
RPC_OPTIMISM=

# Polygon Mainnet
RPC_POLYGON=

# Arbitrum Mainnet
RPC_ARBITRUM=

# Base Mainnet
RPC_BASE=

# Avalanche C-Chain
RPC_AVALANCHE=

# BNB Smart Chain
RPC_BNB=

# Plasma
RPC_PLASMA=

# Hyperliquid EVM
RPC_HYPERLIQUID=

# Ink
RPC_INK=

# Abstract
RPC_ABSTRACT=

# Monad Mainnet
RPC_MONAD=

# Monad Testnet
RPC_MONAD_TESTNET=

# ApeChain
RPC_APECHAIN=

# Degen
RPC_DEGEN=

# Lens
RPC_LENS=

# Unichain
RPC_UNICHAIN=

# MASTER PASSKEY SYSTEM
# =====================
# Admin-only credentials for generating user bypass tokens.
# NEVER commit these values — .env.local is in .gitignore.

# Master passkey hash (SHA256). Generate via: node .master-passkey-setup.cjs "YOUR_PASSKEY"
# You input the raw passkey into your dashboard to unlock admin functions.
MASTER_PASSKEY_HASH=

# Token secret (used to HMAC user keys). Generate: openssl rand -base64 32
# This is used server-side to issue valid one-time tokens for users.
ADMIN_TOKEN_SECRET=

# Vercel KV (Redis) for one-time token tracking
# If not set, one-time enforcement is disabled (tokens can be reused — NOT RECOMMENDED).
# Set via Vercel Dashboard: Settings → Storage → KV
# VERCEL_KV_REST_API_URL=
# VERCEL_KV_REST_API_TOKEN=

# Twitter burner account (for DM integration)
# Used to auto-send thank-you DMs to @hope_ology after key issuance
TWITTER_BURNER_USERNAME=@whiskeystr8shot
TWITTER_BURNER_PASSWORD=

# DM recipient (@hope_ology) — where thank-you notes are sent
TWITTER_DM_TARGET=@hope_ology

# Flashbots ephemeral signing (optional - auto-generated if not set)
FLASHBOTS_EPHEMERAL_KEY=
