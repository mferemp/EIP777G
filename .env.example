# EIP777G — Environment Variables (names only, no values)
# Copy to .env.local and fill in your Alchemy/QuickNode/Infura RPC URLs
# NEVER commit actual values — .env.local is in .gitignore

# Ethereum Mainnet
RPC_ETHEREUM=

# Optimism Mainnet
RPC_OPTIMISM=

# Polygon Mainnet
RPC_POLYGON=

# Arbitrum Mainnet
RPC_ARBITRUM=

# Base Mainnet
RPC_BASE=

# Avalanche C-Chain
RPC_AVALANCHE=

# BNB Smart Chain
RPC_BNB=

# Plasma
RPC_PLASMA=

# Hyperliquid EVM
RPC_HYPERLIQUID=

# Ink
RPC_INK=

# Abstract
RPC_ABSTRACT=

# Monad Mainnet
RPC_MONAD=

# Monad Testnet
RPC_MONAD_TESTNET=

# ApeChain
RPC_APECHAIN=

# Degen
RPC_DEGEN=

# Lens
RPC_LENS=

# Unichain
RPC_UNICHAIN=

# Operator PUBLIC address — safe to put on Vercel. Used to verify bypass tokens.
OPERATOR_ADDRESS=

# Operator SIGNING key — LOCAL ONLY. Never commit, never put on Vercel.
# Generate locally: openssl rand -hex 32
# OPERATOR_SIGNING_KEY=

# Flashbots ephemeral signing (optional - auto-generated if not set)
FLASHBOTS_EPHEMERAL_KEY=
