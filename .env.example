# Helix Fabric / SecureGate v1 — operator environment
# Copy to .env and fill values. Never commit .env.

# ── Operator gate (authorized operator only — never commit real phrase) ───────
# Required for deploy/revoke/rescue API + confidential OPERATOR.md export.
# Must match the veil phrase you enter in the dashboard.
OPERATOR_VEIL_PHRASE=

# Consent phrase — only Empress sets this. Required to alter ACKNOWLEDGEMENT.md.
# Never commit. Assistants and third parties must not know or set this value.
OPERATOR_CONSENT_PHRASE=

# ── Network ──────────────────────────────────────────────────────────────────
RPC_URL=https://ethereum-rpc.publicnode.com
BACKEND_PORT=3001
# BACKEND_HOST=0.0.0.0

# Share (npm run share) — two numerical links:
#   PUBLIC: http://IP:3001/        ← send to friends
#   ADMIN:  http://IP:3001/admin   ← you only
# PUBLIC_IP=24.x.x.x   # optional override; auto-detected for internet link
# Forward router port 3001 for friends outside your Wi‑Fi.

# ── Registry (mainnet deployed) ───────────────────────────────────────────────
GATE_ADDRESS=0x56310d7e48d9249df358ab9daa6a2dad0e03e242

# ── Lane addresses (public on-chain; keys stay offline/ephemeral) ─────────────
K1_ADDRESS=0x01152d5c7467204bFa015061097b193CbceA8ca9
K2_ADDRESS=0x55c73995c4194Dd87CC5aCbC4E45f48c807f4553
CLEAN_WALLET=0xA0eb06a5fab172860837C4D68e75F339896500b5

# ── Keys (relay scripts only — NEVER commit real keys) ────────────────────────
DEPLOYER_PRIVATE_KEY=
K1_PRIVATE_KEY=

# ── Registry constructor params (must match deployed contract) ────────────────
AUTH_WINDOW=3600
MIN_DELAY=900

# ── Gas caps (severance scripts) ──────────────────────────────────────────────
ETH_CAP_WEI=25000000000000000
REVOKE_CAP_WEI=25000000000000000
PRIORITY_GWEI=15

# ── Severance rows (JSON) — or use dashboard Severance tab ────────────────────
# REVOKE_APPROVALS_JSON=[{"type":"erc20","token":"0x…","spender":"0x…"}]
# FUND_K1_WEI=5000000000000000
# ETH mesh bundle: courier privately funds K1 inside 6-builder Flashbots bundle (beats sweeper)
# HL_AGENTS_TO_REVOKE_JSON=[{"agentAddress":"0x…","agentName":"hacker"}]

# ── Multi-chain RPCs + HL Core API ────────────────────────────────────────────
ETH_RPC_URL=
HL_EVM_RPC_URL=
HYPERLIQUID_RPC_URL=
HL_CORE_API_URL=https://api.hyperliquid.xyz/info
BASE_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=
BNB_RPC_URL=
BSC_RPC_URL=

# Per-fabric registry addresses (set after deploy)
SECUREGATE_HL_ADDRESS=
SECUREGATE_BASE_ADDRESS=
SECUREGATE_ARBITRUM_ADDRESS=
SECUREGATE_OPTIMISM_ADDRESS=
SECUREGATE_POLYGON_ADDRESS=
SECUREGATE_BNB_ADDRESS=
HL_CORE_BOOTSTRAPPED=